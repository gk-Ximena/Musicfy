{
  "manifest_version": 3,
  "name": "Musicfy Metadata Bridge",
  "version": "1.0",
  "description": "Sends YouTube Music metadata to Musicfy widget",
  "permissions": ["scripting", "tabs", "activeTab"],
  "host_permissions": ["*://music.youtube.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://music.youtube.com/*"],
      "js": ["inject.js"]
    }
  ]

}
